APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost
# Production (this project): APP_URL=https://aletheiaresourcecenter.com


APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# Default relative path: database/database.sqlite (see config/database.php). Use an absolute
# path in production if the working directory is ambiguous: DB_DATABASE=/workspace/database/database.sqlite
# DB_DATABASE=database/database.sqlite
#
# DigitalOcean App Platform (SQLite, single instance):
# - Set APP_KEY, APP_URL, APP_DEBUG=false, APP_ENV=production in the app (Dashboard → Settings → App-Level Environment Variables or component envs).
# - The local filesystem is ephemeral: data in database.sqlite is lost on redeploy / instance replace unless you restore from backup. Use one web instance (no horizontal scaling) so one SQLite file is canonical.
# - bin/app-platform-start.sh runs migrate, db:seed, schedule:work (Instagram + sitemap), and Apache. Do not add a separate worker: it would not share the same database file.
# - Optional ad-hoc Artisan: doctl apps console <app_id> <component> or the App Platform in-browser console.
# DB_URL=
# DB_FOREIGN_KEYS=true

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Public /blog: max posts in listing and sitemap (keep in sync with INSTAGRAM_SCRAPE_LIMIT when using IG-only feed)
BLOG_LISTING_LIMIT=24

# Instagram scraper
INSTAGRAM_USERNAME=aletheiaresourcecenter
# Max posts to sync per run (CLI, scheduler, CMS); requires pagination past the first ~12
INSTAGRAM_SCRAPE_LIMIT=24
# Cron expression for the scraper schedule (default: daily at 2am UTC)
INSTAGRAM_SCRAPER_CRON="0 2 * * *"

# SEO — see config/seo.php. APP_URL is used as the canonical site URL.
SEO_SITE_NAME="Aletheia Resource Center"
SEO_DEFAULT_TITLE="Aletheia Resource Center"
SEO_DEFAULT_DESCRIPTION="Aletheia Resource Center nurtures curious minds and principled leaders through rigorous academics and dedicated educators."
SEO_DEFAULT_IMAGE=/images/og-default.jpg
SEO_DEFAULT_IMAGE_WIDTH=1200
SEO_DEFAULT_IMAGE_HEIGHT=630
SEO_LOCALE=en_US
SEO_TWITTER_HANDLE=
SEO_THEME_COLOR="#0f172a"
SEO_ORG_NAME="Aletheia Resource Center"
SEO_ORG_LOGO=/images/aletheia-logo.svg
SEO_ORG_TELEPHONE="+60123450702"
SEO_ORG_EMAIL=info@aletheiaacademy.edu.my
SEO_ORG_FACEBOOK=https://www.facebook.com/AletheiaResourceCenter/
SEO_ORG_INSTAGRAM=https://www.instagram.com/aletheiaresourcecenter/
